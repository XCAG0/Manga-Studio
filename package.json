{
  "name": "manga-studio",
  "version": "1.0.0",
  "description": "Professional Manga Translation Studio",
  "main": "electron/main.js",
  "author": "Manga Studio",
  "license": "MIT",
  "scripts": {
    "dev": "vite --strictPort",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "concurrently -k \"npm run dev\" \"wait-on http://localhost:5173 && node scripts/run-electron-dev.cjs\"",
    "electron:dev": "concurrently -k \"npm run dev\" \"wait-on http://localhost:5173 && node scripts/run-electron-dev.cjs\"",
    "electron:build": "npm run build && electron-builder --config electron-builder.config.cjs",
    "electron:build:win": "npm run build && electron-builder --win --x64 --config electron-builder.config.cjs",
    "electron:build:win:log": "npm run build && electron-builder --win --x64 --config electron-builder.config.cjs > buildlog.txt 2>&1",
    "electron:build:mac": "npm run build && electron-builder --mac --config electron-builder.config.cjs",
    "electron:build:linux": "npm run build && electron-builder --linux --config electron-builder.config.cjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.89.0",
    "discord-rpc": "^4.0.1",
    "electron-updater": "^6.6.2",
    "fabric": "^6.0.0",
    "lucide-react": "^0.294.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tesseract.js": "^7.0.0",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.2",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^39.2.7",
    "electron-builder": "^24.13.3",
    "glob": "^13.0.0",
    "vite": "^7.3.0",
    "wait-on": "^7.2.0"
  }
}
